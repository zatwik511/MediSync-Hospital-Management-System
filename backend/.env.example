# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Required: PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Required: port the Express server listens on
PORT=3000

# Required: secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# Required: comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://your-frontend.example.com

# Optional: SMTP settings for appointment reminder emails (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
